generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Smartstore {
  id               String           @id @default(uuid())
  name             String
  sellerId         String           @unique
  storeUrl         String?
  clientId         String?
  clientSecret     String?
  accessToken      String?
  tokenExpiresAt   DateTime?
  naverPartnerType String           @default("SELF")
  naverAccountId   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  products         NaverProduct[]
  orders           Order[]
  priceRules       StorePriceRule[]

  @@index([sellerId])
}

model Sku {
  id                 String                   @id @default(uuid())
  skuCode            String                   @unique
  sellerProductCode  String?
  barcode            String?
  supplierCode       String?
  costPrice          Decimal                  @default(0.0) @db.Decimal(12, 2)
  sellingPrice       Decimal                  @default(0.0) @db.Decimal(12, 2)
  stockQuantity      Int                      @default(0)
  safetyStock        Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  competitorLinks    CompetitorLink[]
  naverProducts      NaverProduct[]
  naverAdditionals   NaverProductAdditional[]
  naverOptions       NaverProductOption[]
  productMappings    NaverProductSku[]
  optionMappings     NaverProductOptionSku[]
  additionalMappings NaverProductAdditionalSku[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  aliases            SkuAlias[]
  barcodes           SkuBarcode[]
  costHistories      SkuCostHistory[]
  storePriceRules    StorePriceRule[]
  syncRule           SyncRule?

  @@index([skuCode])
  @@index([barcode])
  @@index([supplierCode])
}

model NaverProduct {
  id               String                   @id
  smartstoreId     String
  name             String
  naverProductId   String                   @unique
  status           String                   @default("SALE")
  skuId            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  channelProductNo String?                  @unique
  sku              Sku?                     @relation(fields: [skuId], references: [id])
  smartstore       Smartstore               @relation(fields: [smartstoreId], references: [id], onDelete: Cascade)
  additionals      NaverProductAdditional[]
  options          NaverProductOption[]
  skuMappings      NaverProductSku[]

  @@index([smartstoreId])
  @@index([skuId])
  @@index([naverProductId])
}

model NaverProductOption {
  id             String       @id
  naverProductId String
  optionName     String
  optionValue    String
  optionCode     String?
  skuId          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  naverProduct   NaverProduct @relation(fields: [naverProductId], references: [id], onDelete: Cascade)
  sku            Sku?         @relation(fields: [skuId], references: [id])
  skuMappings    NaverProductOptionSku[]

  @@index([naverProductId])
  @@index([skuId])
  @@index([optionCode])
}

model NaverProductAdditional {
  id                   String       @id
  naverProductId       String
  additionalName       String
  additionalValue      String
  price                Int?
  stockQuantity        Int?
  sellerManagementCode String?
  usable               Boolean?
  sortType             String?
  skuId                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  naverProduct         NaverProduct @relation(fields: [naverProductId], references: [id], onDelete: Cascade)
  sku                  Sku?         @relation(fields: [skuId], references: [id])
  skuMappings          NaverProductAdditionalSku[]

  @@index([naverProductId])
  @@index([skuId])
  @@index([sellerManagementCode])
}

model NaverProductSku {
  id             String       @id @default(uuid())
  naverProductId String
  skuId          String
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  naverProduct   NaverProduct @relation(fields: [naverProductId], references: [id], onDelete: Cascade)
  sku            Sku          @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([naverProductId, skuId])
  @@index([naverProductId])
  @@index([skuId])
}

model NaverProductOptionSku {
  id        String             @id @default(uuid())
  optionId  String
  skuId     String
  quantity  Int                @default(1)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  option    NaverProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  sku       Sku                @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([optionId, skuId])
  @@index([optionId])
  @@index([skuId])
}

model NaverProductAdditionalSku {
  id           String                 @id @default(uuid())
  additionalId String
  skuId        String
  quantity     Int                    @default(1)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  additional   NaverProductAdditional @relation(fields: [additionalId], references: [id], onDelete: Cascade)
  sku          Sku                    @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([additionalId, skuId])
  @@index([additionalId])
  @@index([skuId])
}

model StorePriceRule {
  id          String     @id @default(uuid())
  storeId     String
  skuId       String
  fixedPrice  Decimal?   @db.Decimal(12, 2)
  ratePercent Decimal?   @db.Decimal(5, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sku         Sku        @relation(fields: [skuId], references: [id], onDelete: Cascade)
  store       Smartstore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, skuId])
  @@index([storeId])
  @@index([skuId])
}

model SkuAlias {
  id        String   @id @default(uuid())
  skuId     String
  aliasType String
  value     String
  source    String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([skuId, aliasType, value])
  @@index([skuId])
  @@index([aliasType])
  @@index([value])
}

model SkuBarcode {
  id          String   @id @default(uuid())
  skuId       String
  barcode     String
  unitName    String
  quantity    Int      @default(1)
  barcodeType String?
  isPrimary   Boolean  @default(false)
  source      String?
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([skuId, barcode])
  @@index([skuId])
  @@index([barcode])
  @@index([unitName])
}

model SyncRule {
  id          String   @id @default(uuid())
  skuId       String   @unique
  targetPrice Decimal  @db.Decimal(12, 2)
  syncStock   Boolean  @default(true)
  syncPrice   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
}

model SkuCostHistory {
  id            String    @id @default(uuid())
  skuId         String
  costPrice     Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  sku           Sku       @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  supplierId  String
  status      String              @default("PENDING")
  orderDate   DateTime            @default(now())
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  skuId            String
  quantity         Int
  receivedQuantity Int           @default(0)
  unitPrice        Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sku              Sku           @relation(fields: [skuId], references: [id])

  @@index([purchaseOrderId])
  @@index([skuId])
}

model Order {
  id           String      @id @default(uuid())
  smartstoreId String
  naverOrderId String      @unique
  orderDate    DateTime
  totalAmount  Decimal     @db.Decimal(12, 2)
  status       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  smartstore   Smartstore  @relation(fields: [smartstoreId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@index([smartstoreId])
  @@index([naverOrderId])
}

model OrderItem {
  id               String   @id @default(uuid())
  orderId          String
  skuId            String
  quantity         Int
  sellingPrice     Decimal  @db.Decimal(12, 2)
  settlementAmount Decimal  @db.Decimal(12, 2)
  costAtOrder      Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku              Sku      @relation(fields: [skuId], references: [id])

  @@index([orderId])
  @@index([skuId])
}

model CompetitorLink {
  id             String                   @id @default(uuid())
  skuId          String
  competitorName String
  targetUrl      String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  sku            Sku                      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  priceHistories CompetitorPriceHistory[]

  @@index([skuId])
}

model CompetitorPriceHistory {
  id               String         @id @default(uuid())
  competitorLinkId String
  price            Decimal        @db.Decimal(12, 2)
  stockStatus      String?
  checkedAt        DateTime       @default(now())
  competitorLink   CompetitorLink @relation(fields: [competitorLinkId], references: [id], onDelete: Cascade)

  @@index([competitorLinkId])
}
