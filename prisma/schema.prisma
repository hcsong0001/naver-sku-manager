generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Smartstore {
  id                     String                     @id @default(uuid())
  name                   String
  sellerId               String                     @unique
  storeUrl               String?
  clientId               String?
  clientSecret           String?
  accessToken            String?
  tokenExpiresAt         DateTime?
  naverPartnerType       String                     @default("SELF")
  naverAccountId         String?
  naverChannelId         String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  products               NaverProduct[]
  productCollectionJobs  ProductCollectionJob[]
  productCollectionItems ProductCollectionJobItem[]
  importJobs             ImportJob[]
  naverApiCallLogs       NaverApiCallLog[]
  naverApiBatchItems     NaverApiBatchJobItem[]
  orders                 Order[]
  priceRules             StorePriceRule[]

  @@index([sellerId])
}

enum ProductCollectionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProductCollectionJobItemStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ImportJobStatus {
  PENDING
  PREVIEWED
  APPLIED
  FAILED
  CANCELLED
}

enum ImportFileType {
  ERP_STOCK
  SMARTSTORE_PRODUCT
  SKU_MAPPING
  PRODUCT_VARIANT_KEYWORD
}

enum NaverApiCallStatus {
  PENDING
  DRY_RUN
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  RETRY_PENDING
  SKIPPED
  CANCELLED
}

enum NaverApiBatchJobStatus {
  DRAFT
  PREVIEW
  APPROVAL_PENDING
  APPROVED
  EXECUTING
  PARTIAL_SUCCESS
  EXECUTED
  FAILED
  CANCELLED
}

enum NaverApiBatchItemStatus {
  DRAFT
  PREVIEWED
  READY
  EXECUTING
  SUCCESS
  FAILED
  SKIPPED
  RETRY_PENDING
  CANCELLED
}

enum NaverApiBatchFinalApprovalStatus {
  ACTIVE
  INVALIDATED
  SUPERSEDED
}

model Sku {
  id                 String                      @id @default(uuid())
  skuCode            String                      @unique
  sellerProductCode  String?
  barcode            String?
  supplierCode       String?
  costPrice          Decimal                     @default(0.0) @db.Decimal(12, 2)
  sellingPrice       Decimal                     @default(0.0) @db.Decimal(12, 2)
  stockQuantity      Int                         @default(0)
  safetyStock        Int                         @default(0)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  competitorLinks    CompetitorLink[]
  naverProducts      NaverProduct[]
  naverAdditionals   NaverProductAdditional[]
  naverOptions       NaverProductOption[]
  productMappings    NaverProductSku[]
  optionMappings     NaverProductOptionSku[]
  additionalMappings NaverProductAdditionalSku[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  aliases            SkuAlias[]
  barcodes           SkuBarcode[]
  costHistories      SkuCostHistory[]
  storePriceRules    StorePriceRule[]
  syncRule           SyncRule?

  @@index([skuCode])
  @@index([barcode])
  @@index([supplierCode])
}

model NaverProduct {
  id               String                   @id
  smartstoreId     String
  name             String
  naverProductId   String                   @unique
  status           String                   @default("SALE")
  skuId            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  channelProductNo String?                  @unique
  currentSalePrice Int?
  currentStockQuantity Int?
  currentStateSyncedAt DateTime?
  currentStateSource String?
  sku              Sku?                     @relation(fields: [skuId], references: [id])
  smartstore       Smartstore               @relation(fields: [smartstoreId], references: [id], onDelete: Cascade)
  additionals      NaverProductAdditional[]
  options          NaverProductOption[]
  skuMappings      NaverProductSku[]

  @@index([smartstoreId])
  @@index([skuId])
  @@index([naverProductId])
}

model ProductCollectionJob {
  id              String                     @id @default(uuid())
  storeId         String
  status          ProductCollectionJobStatus @default(PENDING)
  searchCondition Json
  totalCount      Int?
  collectedCount  Int                        @default(0)
  successCount    Int                        @default(0)
  failCount       Int                        @default(0)
  currentPage     Int                        @default(1)
  pageSize        Int                        @default(500)
  startedAt       DateTime?
  finishedAt      DateTime?
  errorMessage    String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  store           Smartstore                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items           ProductCollectionJobItem[]

  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model ProductCollectionJobItem {
  id               String                         @id @default(uuid())
  jobId            String
  storeId          String
  channelProductNo String
  originProductNo  String?
  productName      String?
  status           ProductCollectionJobItemStatus @default(PENDING)
  errorMessage     String?
  collectedAt      DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  job              ProductCollectionJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  store            Smartstore                     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([jobId, channelProductNo])
  @@index([jobId])
  @@index([storeId, channelProductNo])
  @@index([status])
}

model ImportJob {
  id                            String                       @id @default(uuid())
  fileType                      ImportFileType
  storeId                       String?
  channelId                     String?
  fileName                      String
  status                        ImportJobStatus              @default(PENDING)
  totalRows                     Int                          @default(0)
  successRows                   Int                          @default(0)
  errorRows                     Int                          @default(0)
  previewSummary                Json?
  errorSummary                  Json?
  appliedAt                     DateTime?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  store                         Smartstore?                  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  files                         ImportFile[]
  stagingStockItems             StagingStockItem[]
  stagingNaverProducts          StagingNaverProduct[]
  stagingNaverProductOptions    StagingNaverProductOption[]
  stagingNaverProductAdditionals StagingNaverProductAdditional[]
  stagingSkuMappings            StagingSkuMapping[]
  stagingProductVariantKeywords StagingProductVariantKeyword[]

  @@index([fileType])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model ImportFile {
  id                            String                       @id @default(uuid())
  jobId                         String
  fileType                      ImportFileType
  fileName                      String
  mimeType                      String?
  sizeBytes                     Int?
  status                        ImportJobStatus              @default(PENDING)
  totalRows                     Int                          @default(0)
  successRows                   Int                          @default(0)
  errorRows                     Int                          @default(0)
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  job                           ImportJob                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stagingStockItems             StagingStockItem[]
  stagingNaverProducts          StagingNaverProduct[]
  stagingNaverProductOptions    StagingNaverProductOption[]
  stagingNaverProductAdditionals StagingNaverProductAdditional[]
  stagingSkuMappings            StagingSkuMapping[]
  stagingProductVariantKeywords StagingProductVariantKeyword[]

  @@index([jobId])
  @@index([fileType])
}

/// 네이버 Commerce API 개별 호출 감사 로그
model NaverApiCallLog {
  id               String             @id @default(uuid())
  smartstoreId     String
  channelId        String?
  batchJobItemId   String?
  module           String
  operation        String
  method           String
  endpoint         String
  requestPayload   Json?
  responsePayload  Json?
  statusCode       Int?
  status           NaverApiCallStatus @default(PENDING)
  errorType        String?
  errorCode        String?
  errorMessage     String?
  attempt          Int                @default(1)
  maxAttempts      Int                @default(1)
  retryAfterMs     Int?
  idempotencyKey   String?
  startedAt        DateTime           @default(now())
  finishedAt       DateTime?
  durationMs       Int?
  createdAt        DateTime           @default(now())
  smartstore       Smartstore         @relation(fields: [smartstoreId], references: [id], onDelete: Restrict)
  batchJobItem     NaverApiBatchJobItem? @relation(fields: [batchJobItemId], references: [id], onDelete: SetNull)

  @@index([smartstoreId, startedAt])
  @@index([channelId])
  @@index([module, operation])
  @@index([status])
  @@index([batchJobItemId])
  @@index([idempotencyKey])
}

/// 네이버 API 대량 변경의 preview, 승인, 실행 상태를 관리하는 작업
model NaverApiBatchJob {
  id             String                       @id @default(uuid())
  jobType        String
  module         String
  status         NaverApiBatchJobStatus      @default(DRAFT)
  dryRun         Boolean                     @default(true)
  description    String?
  totalItems     Int                         @default(0)
  successItems   Int                         @default(0)
  failedItems    Int                         @default(0)
  skippedItems   Int                         @default(0)
  previewSummary Json?
  metadata       Json?
  approvedBy     String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  approvedAt     DateTime?
  executedAt     DateTime?
  items          NaverApiBatchJobItem[]
  finalApprovals NaverApiBatchFinalApproval[]

  @@index([jobType])
  @@index([module])
  @@index([status])
  @@index([createdAt])
}

/// 상품, 옵션, 추가상품 단위의 네이버 API 대량 실행 항목
model NaverApiBatchJobItem {
  id                String                  @id @default(uuid())
  batchJobId        String
  storeId           String
  channelId         String?
  productNo         String?
  channelProductNo  String?
  targetType        String
  targetId          String
  operation         String
  internalSkuCode   String?
  legacyStockCode   String?
  barcode           String?
  skuLookupKeys     Json?
  calculationType   String                  @default("SINGLE")
  bundleComponents  Json?
  calculatedCost    Decimal?                @db.Decimal(12, 2)
  calculatedStock   Int?
  previewBefore     Json?
  previewAfter      Json?
  requestPayload    Json?
  responsePayload   Json?
  status            NaverApiBatchItemStatus @default(DRAFT)
  attemptCount      Int                     @default(0)
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  batchJob          NaverApiBatchJob        @relation(fields: [batchJobId], references: [id], onDelete: Cascade)
  store             Smartstore              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  callLogs          NaverApiCallLog[]
  finalApprovalItems NaverApiBatchFinalApprovalItem[]

  @@index([batchJobId])
  @@index([storeId, channelProductNo])
  @@index([channelId])
  @@index([targetType, targetId])
  @@index([operation])
  @@index([status])
  @@index([internalSkuCode])
  @@index([legacyStockCode])
  @@index([barcode])
}

/// 네이버 API 대량 작업의 LIVE 실행 권한과 검증 근거를 보존하는 최종 승인 artifact
model NaverApiBatchFinalApproval {
  id                     String                             @id @default(uuid())
  jobId                  String
  version                Int
  status                 NaverApiBatchFinalApprovalStatus  @default(ACTIVE)
  finalApprovedAt        DateTime
  finalApprovedBy        String
  finalApprovalMemo      String?
  approvalSource         String
  validationSnapshot     Json
  validationSnapshotHash String                             @db.VarChar(64)
  validationExpiresAt    DateTime
  payloadHash            String                             @db.VarChar(64)
  executionScope         Json
  hashSpec               Json
  invalidatedAt          DateTime?
  invalidatedBy          String?
  invalidationReason     String?
  supersedesApprovalId   String?
  createdAt              DateTime                           @default(now())
  job                    NaverApiBatchJob                   @relation(fields: [jobId], references: [id], onDelete: Restrict)
  items                  NaverApiBatchFinalApprovalItem[]
  supersedes             NaverApiBatchFinalApproval?        @relation("NaverApiBatchFinalApprovalSupersession", fields: [supersedesApprovalId], references: [id], onDelete: Restrict)
  supersededBy           NaverApiBatchFinalApproval[]       @relation("NaverApiBatchFinalApprovalSupersession")

  @@unique([jobId, version])
  @@index([jobId, status])
  @@index([status])
  @@index([supersedesApprovalId])
  @@index([finalApprovedAt])
  @@index([validationExpiresAt])
}

/// 최종 승인 당시 전체 Job Item의 포함·제외 범위와 hash snapshot
model NaverApiBatchFinalApprovalItem {
  id                 String                       @id @default(uuid())
  finalApprovalId    String
  jobItemId          String
  targetType         String
  targetId           String
  storeId            String
  operation          String
  included           Boolean
  excludedReason     String?
  itemPayloadHash    String                       @db.VarChar(64)
  itemValidationHash String                       @db.VarChar(64)
  createdAt          DateTime                     @default(now())
  finalApproval      NaverApiBatchFinalApproval   @relation(fields: [finalApprovalId], references: [id], onDelete: Restrict)
  jobItem            NaverApiBatchJobItem         @relation(fields: [jobItemId], references: [id], onDelete: Restrict)

  @@unique([finalApprovalId, jobItemId])
  @@index([finalApprovalId, included])
  @@index([jobItemId])
  @@index([storeId, targetType, targetId])
}

model StagingStockItem {
  id                  String      @id @default(uuid())
  jobId               String
  importFileId        String?
  rowNumber           Int
  barcode             String
  productName         String
  purchaseProductName String
  internalProductCode String
  modelName           String
  supplierItemCode    String
  optionCode          String
  sellingPrice        Decimal?    @db.Decimal(12, 2)
  costPrice           Decimal?    @db.Decimal(12, 2)
  stockQuantity       Int?
  skuCodeCandidate    String
  sourceRow           Json?
  errorMessage        String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  job                 ImportJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importFile          ImportFile? @relation(fields: [importFileId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([importFileId])
  @@index([barcode])
  @@index([skuCodeCandidate])
}

model StagingNaverProduct {
  id                 String                         @id @default(uuid())
  jobId              String
  importFileId       String?
  storeId            String?
  rowNumber          Int
  externalProductId  String?
  channelProductNo   String?
  originProductNo    String?
  productName        String
  statusType         String?
  sellerManagementCode String?
  sourceRow          Json?
  errorMessage       String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  job                ImportJob                      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importFile         ImportFile?                    @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  options            StagingNaverProductOption[]
  additionals        StagingNaverProductAdditional[]

  @@index([jobId, rowNumber])
  @@index([importFileId])
  @@index([storeId])
  @@index([channelProductNo])
  @@index([originProductNo])
}

model StagingNaverProductOption {
  id               String               @id @default(uuid())
  jobId            String
  importFileId     String?
  stagingProductId String?
  rowNumber        Int
  channelProductNo String?
  optionId         String?
  optionName       String
  optionValue      String
  optionCode       String?
  sourceRow        Json?
  errorMessage     String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  job              ImportJob            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importFile       ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  product          StagingNaverProduct? @relation(fields: [stagingProductId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([importFileId])
  @@index([stagingProductId])
  @@index([channelProductNo])
  @@index([optionCode])
}

model StagingNaverProductAdditional {
  id                   String               @id @default(uuid())
  jobId                String
  importFileId         String?
  stagingProductId     String?
  rowNumber            Int
  channelProductNo     String?
  additionalId         String?
  additionalName       String
  additionalValue      String
  sellerManagementCode String?
  price                Int?
  stockQuantity        Int?
  usable               Boolean?
  sortType             String?
  sourceRow            Json?
  errorMessage         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  job                  ImportJob            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importFile           ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  product              StagingNaverProduct? @relation(fields: [stagingProductId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([importFileId])
  @@index([stagingProductId])
  @@index([channelProductNo])
  @@index([sellerManagementCode])
}

model StagingSkuMapping {
  id               String      @id @default(uuid())
  jobId            String
  importFileId     String?
  rowNumber        Int
  mappingType      String
  smartstoreName   String
  channelProductNo String
  productName      String
  itemId           String
  itemName         String
  managementCode   String
  currentSkuCode   String
  skuCode          String
  quantity         Int
  sourceRow        Json?
  errorMessage     String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  job              ImportJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importFile       ImportFile? @relation(fields: [importFileId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([importFileId])
  @@index([mappingType, itemId])
  @@index([skuCode])
}

model StagingProductVariantKeyword {
  id                      String      @id @default(uuid())
  jobId                   String
  importFileId            String?
  rowNumber               Int
  channelProductNo        String?
  mappingType             String?
  itemId                  String?
  itemName                String?
  serialNo                String
  productMatchName        String
  productOptionText       String
  stockMatchedProductName String
  stockMatchedOptionText  String
  quantityText            String
  resolvedSkuCode         String?
  resolvedModelCodes      String?
  barcode                 String?
  quantity                Int?
  isSetProduct            Boolean     @default(false)
  confidence              Decimal?    @db.Decimal(8, 4)
  warningMessage          String?
  resolvedSkus            Json?
  sourceRow               Json?
  errorMessage            String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  job                     ImportJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importFile              ImportFile? @relation(fields: [importFileId], references: [id], onDelete: SetNull)

  @@index([jobId, rowNumber])
  @@index([importFileId])
  @@index([channelProductNo])
  @@index([mappingType, itemId])
  @@index([serialNo])
}

model NaverProductOption {
  id             String                  @id
  naverProductId String
  optionName     String
  optionValue    String
  optionCode     String?
  skuId          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  currentSalePrice Int?
  currentStockQuantity Int?
  currentStateSyncedAt DateTime?
  currentStateSource String?
  naverProduct   NaverProduct            @relation(fields: [naverProductId], references: [id], onDelete: Cascade)
  sku            Sku?                    @relation(fields: [skuId], references: [id])
  skuMappings    NaverProductOptionSku[]

  @@index([naverProductId])
  @@index([skuId])
  @@index([optionCode])
}

model NaverProductAdditional {
  id                   String                      @id
  naverProductId       String
  additionalName       String
  additionalValue      String
  price                Int?
  stockQuantity        Int?
  sellerManagementCode String?
  usable               Boolean?
  sortType             String?
  skuId                String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  currentStateSyncedAt DateTime?
  currentStateSource String?
  naverProduct         NaverProduct                @relation(fields: [naverProductId], references: [id], onDelete: Cascade)
  sku                  Sku?                        @relation(fields: [skuId], references: [id])
  skuMappings          NaverProductAdditionalSku[]

  @@index([naverProductId])
  @@index([skuId])
  @@index([sellerManagementCode])
}

model NaverProductSku {
  id             String       @id @default(uuid())
  naverProductId String
  skuId          String
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  naverProduct   NaverProduct @relation(fields: [naverProductId], references: [id], onDelete: Cascade)
  sku            Sku          @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([naverProductId, skuId])
  @@index([naverProductId])
  @@index([skuId])
}

model NaverProductOptionSku {
  id        String             @id @default(uuid())
  optionId  String
  skuId     String
  quantity  Int                @default(1)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  option    NaverProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  sku       Sku                @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([optionId, skuId])
  @@index([optionId])
  @@index([skuId])
}

model NaverProductAdditionalSku {
  id           String                 @id @default(uuid())
  additionalId String
  skuId        String
  quantity     Int                    @default(1)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  additional   NaverProductAdditional @relation(fields: [additionalId], references: [id], onDelete: Cascade)
  sku          Sku                    @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([additionalId, skuId])
  @@index([additionalId])
  @@index([skuId])
}

model StorePriceRule {
  id          String     @id @default(uuid())
  storeId     String
  skuId       String
  fixedPrice  Decimal?   @db.Decimal(12, 2)
  ratePercent Decimal?   @db.Decimal(5, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sku         Sku        @relation(fields: [skuId], references: [id], onDelete: Cascade)
  store       Smartstore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, skuId])
  @@index([storeId])
  @@index([skuId])
}

model SkuAlias {
  id        String   @id @default(uuid())
  skuId     String
  aliasType String
  value     String
  source    String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([skuId, aliasType, value])
  @@index([skuId])
  @@index([aliasType])
  @@index([value])
}

model SkuBarcode {
  id          String   @id @default(uuid())
  skuId       String
  barcode     String
  unitName    String
  quantity    Int      @default(1)
  barcodeType String?
  isPrimary   Boolean  @default(false)
  source      String?
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([skuId, barcode])
  @@index([skuId])
  @@index([barcode])
  @@index([unitName])
}

model SyncRule {
  id          String   @id @default(uuid())
  skuId       String   @unique
  targetPrice Decimal  @db.Decimal(12, 2)
  syncStock   Boolean  @default(true)
  syncPrice   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sku         Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
}

model SkuCostHistory {
  id            String    @id @default(uuid())
  skuId         String
  costPrice     Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  sku           Sku       @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  supplierId  String
  status      String              @default("PENDING")
  orderDate   DateTime            @default(now())
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  skuId            String
  quantity         Int
  receivedQuantity Int           @default(0)
  unitPrice        Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sku              Sku           @relation(fields: [skuId], references: [id])

  @@index([purchaseOrderId])
  @@index([skuId])
}

model Order {
  id           String      @id @default(uuid())
  smartstoreId String
  naverOrderId String      @unique
  orderDate    DateTime
  totalAmount  Decimal     @db.Decimal(12, 2)
  status       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  smartstore   Smartstore  @relation(fields: [smartstoreId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@index([smartstoreId])
  @@index([naverOrderId])
}

model OrderItem {
  id               String   @id @default(uuid())
  orderId          String
  skuId            String
  quantity         Int
  sellingPrice     Decimal  @db.Decimal(12, 2)
  settlementAmount Decimal  @db.Decimal(12, 2)
  costAtOrder      Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku              Sku      @relation(fields: [skuId], references: [id])

  @@index([orderId])
  @@index([skuId])
}

model CompetitorLink {
  id             String                   @id @default(uuid())
  skuId          String
  competitorName String
  targetUrl      String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  sku            Sku                      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  priceHistories CompetitorPriceHistory[]

  @@index([skuId])
}

model CompetitorPriceHistory {
  id               String         @id @default(uuid())
  competitorLinkId String
  price            Decimal        @db.Decimal(12, 2)
  stockStatus      String?
  checkedAt        DateTime       @default(now())
  competitorLink   CompetitorLink @relation(fields: [competitorLinkId], references: [id], onDelete: Cascade)

  @@index([competitorLinkId])
}
